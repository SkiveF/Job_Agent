# Exemple de configuration .env
# Copie ce fichier en .env et remplis les valeurs

# Base de données (SQLite par défaut)
DATABASE_URL=sqlite+aiosqlite:///./job_agent.db

# Mode d'application: semi-auto | full-auto
APPLICATION_MODE=semi-auto

# Délais entre actions (en secondes) - pour éviter d'être détecté
MIN_DELAY=3
MAX_DELAY=8

# Proxy (optionnel)
# PROXY_URL=http://user:pass@proxy:port

# Notifications (optionnel)
# DISCORD_WEBHOOK=https://discord.com/api/webhooks/...
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
